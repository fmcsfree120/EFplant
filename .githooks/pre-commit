#!/bin/sh
# EFplant frontend release guard: never let a stale resident process publish
# an index.html generated from an older CACHE_EPOCH.

source_version=$(sed -n "s/.*var CACHE_EPOCH = ['\"]\([^'\"]*\)['\"].*/\1/p" generate_dashboard.py | head -n 1)
staged_version=$(git show :index.html 2>/dev/null | sed -n "s/.*var CACHE_EPOCH = ['\"]\([^'\"]*\)['\"].*/\1/p" | head -n 1)

if [ -z "$source_version" ] || [ -z "$staged_version" ]; then
  echo "[BLOCKED] EFplant frontend version could not be verified."
  exit 1
fi

if [ "$source_version" != "$staged_version" ]; then
  echo "[REPAIR] Stale EFplant frontend detected."
  echo "          generator=$source_version"
  echo "          staged=$staged_version"
  if ! ./.venv/Scripts/python.exe generate_dashboard.py; then
    echo "[BLOCKED] Latest dashboard regeneration failed."
    git restore --staged --worktree -- index.html data.enc health.json service-worker.js known_equipment.json 2>/dev/null || true
    exit 1
  fi
  git add index.html data.enc health.json service-worker.js known_equipment.json
  repaired_version=$(git show :index.html 2>/dev/null | sed -n "s/.*var CACHE_EPOCH = ['\"]\([^'\"]*\)['\"].*/\1/p" | head -n 1)
  if [ "$source_version" != "$repaired_version" ]; then
    echo "[BLOCKED] Regenerated frontend still has the wrong version."
    git restore --staged --worktree -- index.html data.enc health.json service-worker.js known_equipment.json 2>/dev/null || true
    exit 1
  fi
  echo "[OK] EFplant stale output repaired: $repaired_version"
  staged_version=$repaired_version
fi

echo "[OK] EFplant release guard: $staged_version"
exit 0
